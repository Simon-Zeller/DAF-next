{
  "name": "@daf/brand-interview-cli",
  "version": "0.1.0",
  "description": "Pre-pipeline Brand Interview CLI — Conducts structured brand interviews and outputs brand-profile.json",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "brand-interview": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@inquirer/prompts": "^3.3.0",
    "commander": "^12.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitest/coverage-v8": "^1.1.0",
    "eslint": "^8.54.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "keywords": [
    "brand",
    "interview",
    "cli",
    "design",
    "designops",
    "agentic"
  ],
  "author": "Simon Zeller",
  "license": "MIT"
}
